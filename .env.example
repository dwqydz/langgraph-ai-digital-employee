# AI数字员工系统环境配置示例
# 复制此文件为 .env 并填入实际配置

# 通义千问 API Key（必需）
# 从阿里云DashScope获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-api-key-here

# JWT密钥（生产环境请修改为强随机字符串）
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./ai_employee.db

# 服务器配置
HOST=0.0.0.0
PORT=8080
